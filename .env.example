# API Troubleshooting Playground - Environment Configuration
# Copy this file to .env and update the values for your environment

# ===========================================
# CLIENT / FRONTEND CONFIGURATION
# ===========================================

# API Base URL - How the frontend communicates with the backend
# 
# FOR VERCEL DEPLOYMENT:
# Deploy your backend separately (Render, Railway, etc.) and set the URL here:
# Example: https://your-backend-name.onrender.com
VITE_API_BASE_URL=https://your-backend-url.onrender.com

# Base path for the frontend (use "/" for root)
VITE_BASE_PATH=/

# ===========================================
# SERVER / BACKEND CONFIGURATION
# ===========================================

# Development settings (used when NODE_ENV is not 'production')
DEV_PORT=3001
DEV_NODE_ENV=development
DEV_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Production settings (uncomment and configure for production)
# PORT=3001
# NODE_ENV=production
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# VERCEL DEPLOYMENT NOTES:
# ===========================================
# 1. Deploy backend to Render.com, Railway.app, or similar
# 2. Copy your backend URL (e.g., https://api-xxx.onrender.com)
# 3. Set VITE_API_BASE_URL to that URL in Vercel project settings
# 4. Add your Vercel domain to ALLOWED_ORIGINS on the backend
