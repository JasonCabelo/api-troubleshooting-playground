# API Troubleshooting Playground - Environment Variables
# Copy this file based on your environment

# ============================================
# DEVELOPMENT ENVIRONMENT
# ============================================
# Server Configuration
DEV_PORT=3001
DEV_NODE_ENV=development
DEV_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Client Configuration
VITE_API_BASE_URL=http://localhost:3001
VITE_BASE_URL=/

# ============================================
# PRODUCTION ENVIRONMENT
# ============================================
# Uncomment and update these for production:
# PORT=3001
# NODE_ENV=production
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_BASE_URL=/
